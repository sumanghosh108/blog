---
/**
 * BlogLayout - Layout component for blog post pages
 * Extends BaseLayout with blog-specific metadata display and features
 * 
 * Validates Requirements: 3.1, 3.2, 3.3, 3.4, 3.5, 3.8
 */

import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { formatDate } from '../utils/date';
import { calculateReadingTime } from '../utils/readingTime';
import type { ReadingTimeResult } from '../utils/readingTime';

interface Heading {
  depth: number;
  text: string;
  slug: string;
}

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  author: string;
  tags: string[];
  image?: string;
  headings: Heading[];
  content: string;
}

const { 
  title, 
  description, 
  publishDate, 
  author, 
  tags, 
  image,
  headings,
  content
} = Astro.props;

// Calculate reading time from content
const readingTime: ReadingTimeResult = calculateReadingTime(content);

// Format the publish date
const formattedDate = formatDate(publishDate);
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishDate={publishDate}
  tags={tags}
>
  <article class="max-w-4xl mx-auto px-4 py-8">
    <!-- Post Header -->
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-gray-900 dark:text-gray-100">
        {title}
      </h1>
      
      <!-- Post Metadata -->
      <div class="flex flex-wrap items-center gap-4 text-gray-600 dark:text-gray-400 mb-6">
        <div class="flex items-center gap-2">
          <span class="font-medium">By {author}</span>
        </div>
        
        <div class="flex items-center gap-2">
          <time datetime={publishDate.toISOString()}>
            {formattedDate}
          </time>
        </div>
        
        <div class="flex items-center gap-2">
          <span>{readingTime.text}</span>
        </div>
      </div>
      
      <!-- Tags -->
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
              class="px-3 py-1 text-sm bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- Main Content Area with Sidebar -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_250px] gap-8">
      <!-- Post Content -->
      <div class="prose prose-lg dark:prose-invert max-w-none">
        <slot />
      </div>
      
      <!-- Sidebar (Desktop) -->
      <aside class="hidden lg:block">
        <div class="sticky top-8">
          <!-- TableOfContents Component -->
          {headings && headings.length > 0 && (
            <div class="mb-8">
              <TableOfContents headings={headings} />
            </div>
          )}
          
          <!-- ShareButtons Component Placeholder -->
          <!-- Will be implemented in Task 4.6 -->
          <div>
            <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-gray-100">
              Share this post
            </h2>
            <!-- <ShareButtons title={title} url={Astro.url.toString()} /> -->
            <p class="text-sm text-gray-500 dark:text-gray-400 italic">
              ShareButtons component will be added in Task 4.6
            </p>
          </div>
        </div>
      </aside>
    </div>
    
    <!-- Mobile Table of Contents (Below Content) -->
    {headings && headings.length > 0 && (
      <div class="lg:hidden mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
        <TableOfContents headings={headings} />
      </div>
    )}
    
    <!-- Mobile Share Buttons (Below Content) -->
    <div class="lg:hidden mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-gray-100">
        Share this post
      </h2>
      <!-- <ShareButtons title={title} url={Astro.url.toString()} /> -->
      <p class="text-sm text-gray-500 dark:text-gray-400 italic">
        ShareButtons component will be added in Task 4.6
      </p>
    </div>
  </article>
</BaseLayout>
