---
/**
 * PostCard Component - Blog post preview card
 * Displays post title, description, publish date, tags, and featured badge
 * Provides hover effects and links to full post with responsive layout
 * 
 * Validates Requirements: 2.3, 2.4, 2.6
 */

interface Props {
  slug: string;
  title: string;
  description: string;
  publishDate: Date;
  tags: string[];
  image?: string;
  featured?: boolean;
}

const { slug, title, description, publishDate, tags, image, featured = false } = Astro.props;

// Format date for display
const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article
  class="group relative flex flex-col h-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden transition-all duration-300 hover:shadow-lg hover:border-blue-500 dark:hover:border-blue-400 hover:-translate-y-1"
>
  <!-- Featured Badge -->
  {featured && (
    <div class="absolute top-4 right-4 z-10">
      <span class="inline-flex items-center rounded-full bg-blue-600 dark:bg-blue-500 px-3 py-1 text-xs font-semibold text-white shadow-lg">
        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        Featured
      </span>
    </div>
  )}

  <!-- Image (if provided) -->
  {image && (
    <div class="aspect-video w-full overflow-hidden bg-gray-100 dark:bg-gray-800">
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    </div>
  )}

  <!-- Card Content -->
  <div class="flex flex-1 flex-col p-6">
    <!-- Publish Date -->
    <time
      datetime={publishDate.toISOString()}
      class="text-sm text-gray-600 dark:text-gray-400 mb-2"
    >
      {formattedDate}
    </time>

    <!-- Title -->
    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
      <a href={`${import.meta.env.BASE_URL}blog/${slug}`} class="hover:underline">
        {title}
      </a>
    </h3>

    <!-- Description -->
    <p class="text-gray-600 dark:text-gray-400 mb-4 line-clamp-3 flex-grow">
      {description}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-auto">
        {tags.map((tag) => (
          <a
            href={`${import.meta.env.BASE_URL}tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
            class="inline-flex items-center rounded-md bg-gray-100 dark:bg-gray-800 px-2.5 py-1 text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:text-blue-700 dark:hover:text-blue-400 transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
    )}
  </div>

  <!-- Read More Link (invisible overlay for entire card clickability) -->
  <a
    href={`${import.meta.env.BASE_URL}blog/${slug}`}
    class="absolute inset-0"
    aria-label={`Read more about ${title}`}
  >
    <span class="sr-only">Read more about {title}</span>
  </a>
</article>
