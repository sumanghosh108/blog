---
/**
 * Logo Component - Site branding logo
 * Renders the site logo with proper accessibility and performance attributes
 * 
 * Validates Requirements: 1.1, 1.2, 1.4, 4.1, 4.2, 6.1, 6.2
 */
---

<a 
  href={import.meta.env.BASE_URL} 
  class="inline-block transition-opacity hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 rounded"
>
  <img 
    src={`${import.meta.env.BASE_URL}logo.png`}
    alt="SUMAN ANALYST HL NADA - Site Logo"
    width="180"
    height="48"
    loading="eager"
    decoding="async"
    class="h-16 md:h-20 w-auto"
  />
</a>
